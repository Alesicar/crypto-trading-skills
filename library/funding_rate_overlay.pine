// ============================================================
// Funding Rate Overlay — Manual Input Table Display
// ============================================================
// Displays the current funding rate as a table overlay on the
// chart. Since TradingView doesn't provide native funding rate
// data, this uses manual input fields. Update the values from
// your exchange or use TradingView's Pine editor to set them.
//
// Features:
//   - Color-coded funding rate (green=positive, red=negative)
//   - Annualized rate calculation
//   - Sentiment indicator (Bullish/Bearish/Neutral)
//   - Configurable table position
//
// Best on: any crypto perpetual futures chart.
// ============================================================

//@version=6
indicator("Funding Rate Overlay", overlay=true)

// ── Inputs ──────────────────────────────────────────────────
funding_rate   = input.float(0.01, "Current Funding Rate (%)", step=0.001,
                  tooltip="Enter the current 8h funding rate percentage",
                  group="Funding Data")
countdown_hrs  = input.float(4.0, "Hours Until Next Funding", step=0.5,
                  minval=0.0, maxval=8.0, group="Funding Data")
exchange_name  = input.string("Binance", "Exchange",
                  options=["Binance", "Bybit", "OKX", "Bitget", "dYdX"],
                  group="Funding Data")

// Table position
tbl_pos = input.string("Top Right", "Table Position",
           options=["Top Left", "Top Center", "Top Right",
                    "Bottom Left", "Bottom Center", "Bottom Right"],
           group="Display")
tbl_size = input.string("normal", "Text Size",
            options=["tiny", "small", "normal", "large"],
            group="Display")

// Thresholds for color coding
high_thresh = input.float(0.05, "High Rate Threshold (%)", step=0.01, group="Thresholds")
extreme_thresh = input.float(0.1, "Extreme Rate Threshold (%)", step=0.01, group="Thresholds")

// ── Calculations ───────────────────────────────────────────
// Annualized rate: 3 funding periods per day × 365 days
annual_rate = funding_rate * 3.0 * 365.0

// Sentiment based on funding rate
sentiment = funding_rate > extreme_thresh ? "Very Bullish" :
            funding_rate > high_thresh ? "Bullish" :
            funding_rate > 0.005 ? "Slightly Bullish" :
            funding_rate < -extreme_thresh ? "Very Bearish" :
            funding_rate < -high_thresh ? "Bearish" :
            funding_rate < -0.005 ? "Slightly Bearish" : "Neutral"

// ── Color Logic ────────────────────────────────────────────
rate_color = math.abs(funding_rate) >= extreme_thresh ?
             (funding_rate > 0 ? color.lime : color.fuchsia) :
             math.abs(funding_rate) >= high_thresh ?
             (funding_rate > 0 ? color.green : color.red) :
             funding_rate > 0 ? color.new(color.green, 30) :
             funding_rate < 0 ? color.new(color.red, 30) : color.gray

// ── Table Position Mapping ─────────────────────────────────
pos = tbl_pos == "Top Left" ? position.top_left :
      tbl_pos == "Top Center" ? position.top_center :
      tbl_pos == "Top Right" ? position.top_right :
      tbl_pos == "Bottom Left" ? position.bottom_left :
      tbl_pos == "Bottom Center" ? position.bottom_center :
      position.bottom_right

txt_size = tbl_size == "tiny" ? size.tiny :
           tbl_size == "small" ? size.small :
           tbl_size == "large" ? size.large : size.normal

// ── Table Display ──────────────────────────────────────────
var table info_table = table.new(pos, 2, 6, bgcolor=color.new(color.black, 20),
                                  border_width=1, border_color=color.gray)

if barstate.islast
    // Header
    table.cell(info_table, 0, 0, "Funding Rate", text_color=color.white,
               text_size=txt_size, bgcolor=color.new(color.gray, 50))
    table.cell(info_table, 1, 0, exchange_name, text_color=color.white,
               text_size=txt_size, bgcolor=color.new(color.gray, 50))
    table.merge_cells(info_table, 0, 0, 1, 0)

    // Current rate
    table.cell(info_table, 0, 1, "8h Rate", text_color=color.silver, text_size=txt_size)
    table.cell(info_table, 1, 1, str.tostring(funding_rate, "#.####") + "%",
               text_color=rate_color, text_size=txt_size)

    // Annualized rate
    table.cell(info_table, 0, 2, "Annual", text_color=color.silver, text_size=txt_size)
    table.cell(info_table, 1, 2, str.tostring(annual_rate, "#.##") + "%",
               text_color=rate_color, text_size=txt_size)

    // Sentiment
    table.cell(info_table, 0, 3, "Sentiment", text_color=color.silver, text_size=txt_size)
    table.cell(info_table, 1, 3, sentiment, text_color=rate_color, text_size=txt_size)

    // Countdown
    table.cell(info_table, 0, 4, "Next In", text_color=color.silver, text_size=txt_size)
    table.cell(info_table, 1, 4, str.tostring(countdown_hrs, "#.#") + "h",
               text_color=color.white, text_size=txt_size)

    // Payment direction
    pay_dir = funding_rate > 0 ? "Longs pay Shorts" :
              funding_rate < 0 ? "Shorts pay Longs" : "No payment"
    table.cell(info_table, 0, 5, "Payment", text_color=color.silver, text_size=txt_size)
    table.cell(info_table, 1, 5, pay_dir, text_color=rate_color, text_size=txt_size)

// ── Alerts ─────────────────────────────────────────────────
alertcondition(math.abs(funding_rate) >= extreme_thresh, title="Extreme Funding",
               message="Extreme funding rate on {{ticker}}: " + str.tostring(funding_rate) + "%")

// Want real-time SMC alerts? → smc-field-guide.netlify.app
